# ⚠️  NEVER commit this file to git — .gitignore already excludes it
# FIX #5 — all real credentials removed; fill in your own values below
# ⚠️  ROTATE ALL YOUR KEYS immediately — they were exposed in the zip file

# ── Supabase ──────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ── Backblaze B2 / R2-compatible storage ──────────────────────────────
# FIX #17 — no trailing space after bucket name
R2_ENDPOINT_URL=https://s3.us-west-004.backblazeb2.com
R2_ACCESS_KEY_ID=YOUR_ACCESS_KEY_ID
R2_SECRET_ACCESS_KEY=YOUR_SECRET_ACCESS_KEY
R2_BUCKET_NAME=brain-tumour-scans

# ── Qdrant ────────────────────────────────────────────────────────────
QDRANT_URL=https://YOUR_CLUSTER.qdrant.io
QDRANT_API_KEY=YOUR_QDRANT_API_KEY
QDRANT_COLLECTION_NAME=clinical_guidelines

# ── Groq ──────────────────────────────────────────────────────────────
GROQ_API_KEY=YOUR_GROQ_API_KEY

# ── Modal ─────────────────────────────────────────────────────────────
# No trailing space after URL
MODAL_WEBHOOK_URL=https://YOUR_MODAL_APP--brain-tumour-segmentation.modal.run

# ── JWT — generate with: openssl rand -hex 32 ─────────────────────────
JWT_SECRET_KEY=YOUR_GENERATED_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── CORS — set to your actual frontend domain in production ───────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,https://your-frontend-domain.com

# ── RAG tuning ────────────────────────────────────────────────────────
RAG_MIN_RELEVANCE_SCORE=0.45
RAG_MAX_PASSAGES=5
CHUNK_SIZE=800
CHUNK_OVERLAP=100

# Fix R6 — shared secret for Modal webhook auth; generate: openssl rand -hex 32
MODAL_WEBHOOK_SECRET=YOUR_GENERATED_SECRET
