# ─────────────────────────────────────────────────────────────────────────────
# CBTA Frontend — Environment variables
#
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.
# ─────────────────────────────────────────────────────────────────────────────

# URL of your deployed Render FastAPI backend.
# All API calls go directly here — no Next.js proxy.
# Include the protocol, no trailing slash.
# Example: https://cbta-api.onrender.com
NEXT_PUBLIC_API_BASE=https://your-render-app.onrender.com
